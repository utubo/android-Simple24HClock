<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.Simple24HClock.AppWidget.Container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/Container">


    <RelativeLayout
        android:id="@+id/RotateBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/BackImageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/back"
            tools:ignore="ContentDescription" />

        <ImageView
            android:id="@+id/BorderImageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/border"
            app:tint="@color/white"
            tools:ignore="ContentDescription" />

        <ImageView
            android:id="@+id/DotsImageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/dots"
            app:tint="@color/white"
            tools:ignore="ContentDescription" />

        <ImageView
            android:id="@+id/SunImageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/sun"
            app:tint="@color/white"
            tools:ignore="ContentDescription" />

        <ImageView
            android:id="@+id/MoonImageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/moon"
            app:tint="@color/white"
            tools:ignore="ContentDescription" />
    </RelativeLayout>

    <ImageView
        android:id="@+id/DayOfYearDotsImageView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:src="@drawable/face_day_of_year"
        app:tint="@color/white"
        tools:ignore="ContentDescription" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text=""
        android:textColor="#88FFFFFF"
        app:tint="@color/white"
        app:layout_constraintVertical_weight="1" />

    <ImageView
        android:id="@+id/MinuteHandImageView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:src="@drawable/hand_minute"
        app:tint="@color/white"
        tools:ignore="ContentDescription" />

    <RelativeLayout
        android:id="@+id/RotateFg"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/DayOfYearHandImageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0"
            android:src="@drawable/hand_day_of_year"
            app:tint="@color/white"
            tools:ignore="ContentDescription" />

        <ImageView
            android:id="@+id/HourHandImageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/hand"
            app:tint="@color/white"
            tools:ignore="ContentDescription" />
    </RelativeLayout>

</RelativeLayout>